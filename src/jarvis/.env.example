# ============================================================
# JARVIS — Environment Variables
# Copy to .env and fill in the values you need.
# setup.sh will create .env interactively for you.
# ============================================================

# ── Required ─────────────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── TTS Engine ───────────────────────────────────────────────
# "edge"  → free Microsoft Edge TTS (no key needed, works offline-ish)
# "fish"  → premium Fish Audio voice (needs FISH_API_KEY below)
TTS_ENGINE=edge

# ── Fish Audio (only if TTS_ENGINE=fish) ────────────────────
# API key from https://fish.audio
FISH_API_KEY=

# Fish Audio voice ID — default is the MCU JARVIS voice
# Browse voices at https://fish.audio/voices
FISH_VOICE_ID=612b878b113047d9a770c069c8b4fdfe

# ── Personalisation ──────────────────────────────────────────
# How JARVIS addresses you
USER_NAME=sir

# ── Auth ─────────────────────────────────────────────────────
# Bearer token protecting all JARVIS API endpoints.
# Leave blank to auto-generate a random token on first boot.
JARVIS_AUTH_TOKEN=

# ── Server ───────────────────────────────────────────────────
# Port the Python server listens on (default 8340)
JARVIS_PORT=8340
