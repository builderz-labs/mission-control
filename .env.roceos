# ═════��═════════════════════════════════════════════════════════════
# RoceOS — ALL credentials in ONE file
# This is the ONLY .env file. All services read from here.
# NEVER commit this file to git (it's in .gitignore)
# ═══════════════════════════════════════════════════════════════════

# ── LLM Mode ─────────────────────────────────────────────────────
# "cli" = Claude Code CLI (Max subscription, $0 cost) — DEFAULT
# "api" = Anthropic API via LiteLLM proxy (costs money)
ROCEOS_LLM_MODE=cli
ANTHROPIC_API_KEY=

# ── Mission Control ──────────────────────────────────────────────
PORT=3000
AUTH_USER=ross
AUTH_PASS=
MC_API_KEY=
NEXT_PUBLIC_GATEWAY_OPTIONAL=true

# ── Telegram (RoceOS Bot) ��──────────────────────────────────────
ROCEOS_TELEGRAM_BOT_TOKEN=
ROCEOS_TELEGRAM_USER_ID=8787239235

# ── Discord (Captain Hook) ──────��───────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=1071958693236715551

# ���─ Trading (Alpaca Live) ───��───────────────────────────────────
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=
ALPACA_LIVE_URL=https://api.alpaca.markets

# ── Trading (Alpaca Paper) ──���───────────────────────────────────
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=
ALPACA_PAPER_URL=https://paper-api.alpaca.markets

# ── Discord Webhooks (Trading Alerts) ───────────────────────────
DISCORD_WEBHOOK_DAILY=
DISCORD_WEBHOOK_1H=
DISCORD_WEBHOOK_15M=
DISCORD_WEBHOOK_ICT_ALERTS=

# ── TradingView Webhook ────────────────────────────────────────
WEBHOOK_SECRET=

# ── External APIs ───────────────────────────────────────────────
GITHUB_TOKEN=
BRAVE_SEARCH_KEY=

# ── Google (OAuth) ─────��───────────────────────────────���────────
GOOGLE_TOKEN_PATH=/app/data/google_token.json

# ── Infrastructure ────���─────────────────────────────────────────
UNIFI_HOST=
UNIFI_USERNAME=
UNIFI_PASSWORD=
REDIS_URL=redis://redis:6379
LITELLM_BASE_URL=http://litellm:4000
