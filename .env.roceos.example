# RoceOS Environment — VPS Deployment
# Copy to .env: cp .env.roceos.example .env
# Then fill in your actual values.

# ── Server ──
PORT=3000

# ── Authentication ──
AUTH_USER=ross
AUTH_PASS=CHANGE_ME_TO_STRONG_PASSWORD
# MC_ALLOWED_HOSTS should include your VPS IP or domain
MC_ALLOWED_HOSTS=localhost,127.0.0.1,::1,187.127.96.74
MC_ALLOW_ANY_HOST=true

# ── Standalone Mode (no OpenClaw gateway) ──
NEXT_PUBLIC_GATEWAY_OPTIONAL=true

# ── Anthropic API (used by LiteLLM) ──
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── LiteLLM ──
LITELLM_MASTER_KEY=sk-roceos-change-me

# ── Data Retention ──
MC_RETAIN_ACTIVITIES_DAYS=90
MC_RETAIN_AUDIT_DAYS=365
MC_RETAIN_LOGS_DAYS=30
MC_RETAIN_TOKEN_USAGE_DAYS=90
