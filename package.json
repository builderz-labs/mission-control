{
  "name": "ultron-mission-control",
  "version": "1.0.0",
  "description": "Ultron Mission Control — autonomous agent orchestration dashboard built by Tony W. for Mantu Group",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "verify:node": "node scripts/check-node-version.mjs",
    "dev": "pnpm run verify:node && bash scripts/jarvis-ensure.sh && next dev --hostname 127.0.0.1 --port ${PORT:-3000}",
    "build": "pnpm run verify:node && next build",
    "start": "pnpm run verify:node && next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "start:standalone": "pnpm run verify:node && bash scripts/start-standalone.sh",
    "deploy:standalone": "pnpm run verify:node && bash scripts/deploy-standalone.sh",
    "lint": "pnpm run verify:node && eslint .",
    "typecheck": "pnpm run verify:node && tsc --noEmit",
    "test": "pnpm run verify:node && vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "pnpm run verify:node && playwright test",
    "test:e2e:openclaw:local": "pnpm run verify:node && E2E_GATEWAY_EXPECTED=0 playwright test -c playwright.openclaw.local.config.ts",
    "test:e2e:openclaw:gateway": "pnpm run verify:node && E2E_GATEWAY_EXPECTED=1 playwright test -c playwright.openclaw.gateway.config.ts",
    "test:e2e:openclaw": "pnpm test:e2e:openclaw:local && pnpm test:e2e:openclaw:gateway",
    "test:all": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e",
    "quality:gate": "pnpm test:all",
    "jarvis:sync": "node scripts/jarvis-sync-token.mjs",
    "jarvis:install": "cd src/jarvis && pip3 install -r requirements.txt",
    "jarvis:start": "cd src/jarvis && python3 server.py --host localhost --port 8340",
    "jarvis:dev": "pnpm jarvis:start & pnpm dev",
    "wiki:generate": "tsx scripts/wiki-gen/run.ts",
    "wiki:generate:force": "tsx scripts/wiki-gen/run.ts --force",
    "wiki:qa": "tsx scripts/wiki-gen/qa.ts",
    "wiki:qa:repl": "tsx scripts/wiki-gen/qa.ts --interactive",
    "wiki:lint": "tsx scripts/wiki-gen/lint-heal.ts",
    "wiki:heal": "tsx scripts/wiki-gen/lint-heal.ts --fix",
    "wiki:search": "tsx scripts/wiki-gen/search.ts",
    "wiki:slides": "tsx scripts/wiki-gen/slides.ts",
    "wiki:report": "tsx scripts/wiki-gen/report.ts",
    "wiki:report:no-db": "tsx scripts/wiki-gen/report.ts --no-db",
    "wiki:all": "pnpm wiki:generate && pnpm wiki:slides && pnpm wiki:report"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@scalar/api-reference-react": "^0.8.66",
    "@xyflow/react": "^12.10.0",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.1.6",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "postcss": "^8.5.2",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "reagraph": "^4.30.8",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "three": "^0.183.2",
    "typescript": "^5.7.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@playwright/test": "^1.51.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.6",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^26.0.0",
    "pino-pretty": "^13.1.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.5"
  },
  "keywords": [
    "openclaw",
    "agent",
    "orchestration",
    "dashboard",
    "nextjs"
  ],
  "author": "Tony W. (Mantu Group)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/builderz-labs/mission-control.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
