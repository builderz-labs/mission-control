# =============================================================================
# Ultron Mission Control — Environment Configuration
# Copy to .env.local (development) or .env (production).
# Never commit real secrets. This file documents shape and purpose only.
# =============================================================================


# =============================================================================
# Auth
# =============================================================================

# Admin credentials seeded on first run (only when no users exist in DB).
AUTH_USER=admin
AUTH_PASS=change-me-on-first-login

# Alternative: base64-encode AUTH_PASS when the value contains "#" characters.
# Generate: echo -n 'my#password' | base64
# AUTH_PASS_B64=Y2hhbmdlLW1lLW9uLWZpcnN0LWxvZ2lu

# Shared secret used by legacy cookie-based auth. Kept for backward compatibility;
# remove once all active sessions have migrated to the __Host-prefixed session cookie.
AUTH_SECRET=random-secret-for-legacy-cookies

# API key for headless / external access (x-api-key header or Bearer token).
# Generate with: openssl rand -hex 32
API_KEY=generate-a-random-key

# Google OAuth client ID for the Google Sign-In approval workflow.
# Create a Web Application credential in Google Cloud Console.
# Server-side ID (kept out of the browser bundle for defense-in-depth).
GOOGLE_CLIENT_ID=
# Client-side ID (safe to expose; used by the Google Identity JavaScript library).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=


# =============================================================================
# Network & Public URL
# =============================================================================

# Canonical public URL for Open Graph metadata and absolute link generation.
# Tried in order: NEXT_PUBLIC_APP_URL -> MC_PUBLIC_BASE_URL -> APP_URL -> MISSION_CONTROL_PUBLIC_URL.
NEXT_PUBLIC_APP_URL=
MC_PUBLIC_BASE_URL=
APP_URL=
MISSION_CONTROL_PUBLIC_URL=

# Internal base URL used for server-side self-calls (e.g. health probes, status API).
# Defaults to http://localhost:PORT when unset.
MC_BASE_URL=

# Hostname advertised in tenant-scoped migrations and multi-host setups.
# Defaults to the system hostname when unset.
MC_HOSTNAME=

# Port the Next.js server listens on (dev and production).
# PORT=3000


# =============================================================================
# Session Cookie
# =============================================================================

# Force secure=true on all session cookies even when the request is HTTP.
# Leave blank to auto-detect (secure on HTTPS, insecure on HTTP).
MC_COOKIE_SECURE=

# SameSite policy for the session cookie. Defaults to "strict".
# Valid values: strict | lax | none
MC_COOKIE_SAMESITE=strict


# =============================================================================
# Access Control (Middleware)
# =============================================================================

# In production, all requests are blocked by default unless the origin host
# matches one of the patterns below. In dev/test, all hosts are allowed.
# Patterns: exact ("app.example.com"), subdomain ("*.example.com"), prefix ("100.*").
MC_ALLOW_ANY_HOST=
MC_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted reverse-proxy IP addresses.
# When set, the middleware trusts X-Forwarded-For only from these sources.
MC_TRUSTED_PROXIES=

# Transparent proxy authentication: if your reverse proxy injects an auth
# header (e.g. X-Remote-User), set MC_PROXY_AUTH_HEADER to that header name.
# MC_PROXY_AUTH_HEADER=X-Remote-User

# Default role assigned to users authenticated via proxy header.
# MC_PROXY_AUTH_DEFAULT_ROLE=viewer

# Enable HTTP Strict Transport Security (HSTS). Set to 1 when deployed over HTTPS.
MC_ENABLE_HSTS=

# Disable rate limiting globally (DANGER: never set in production).
MC_DISABLE_RATE_LIMIT=


# =============================================================================
# Logging
# =============================================================================

# Server log level. One of: trace | debug | info | warn | error | fatal | silent.
LOG_LEVEL=info


# =============================================================================
# OpenClaw Integration
# =============================================================================

# Root directory of the OpenClaw installation (~/.openclaw by default).
OPENCLAW_HOME=

# Override the path to openclaw.json config (derived from OPENCLAW_HOME if unset).
# OPENCLAW_CONFIG_PATH=

# Path used by the memory browser and workspace features.
# OPENCLAW_STATE_DIR defaults to OPENCLAW_HOME.
# OPENCLAW_STATE_DIR=

# Workspace directory managed by OpenClaw. Skills from here appear in the
# workspace skills panel.
# OPENCLAW_WORKSPACE_DIR=

# Explicit path to the openclaw binary (defaults to "openclaw" on PATH).
# OPENCLAW_BIN=openclaw

# Log and memory directories (derived from OPENCLAW_HOME when not set).
# OPENCLAW_LOG_DIR=/path/to/.openclaw/logs
# OPENCLAW_MEMORY_DIR=/path/to/.openclaw/memory

# Soul template directory for agent personality files.
# OPENCLAW_SOUL_TEMPLATES_DIR=/path/to/.openclaw/templates/souls

# Alternate path to openclaw.json when used alongside MISSION_CONTROL_ prefix paths.
# MISSION_CONTROL_OPENCLAW_CONFIG_PATH=
# MISSION_CONTROL_OPENCLAW_HOME=


# =============================================================================
# Gateway Connection (WebSocket)
# =============================================================================

# Server-side gateway credentials used by API route calls.
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_GATEWAY_URL=

# Legacy / alias names (kept for compatibility with older configs).
GATEWAY_TOKEN=
GATEWAY_PASSWORD=
GATEWAY_PORT=

# Client-side gateway connection (available in the browser bundle).
NEXT_PUBLIC_GATEWAY_HOST=
NEXT_PUBLIC_GATEWAY_PORT=18789
NEXT_PUBLIC_GATEWAY_PROTOCOL=
# Full WebSocket URL. When set, overrides HOST + PORT + PROTOCOL.
NEXT_PUBLIC_GATEWAY_URL=
# Role identifier sent in the WebSocket connect handshake.
NEXT_PUBLIC_GATEWAY_CLIENT_ID=openclaw-control-ui
# Optional mode: set to 'true' when the WebSocket port is firewalled.
# Core CRUD features work; live gateway events are disabled.
# NEXT_PUBLIC_GATEWAY_OPTIONAL=false


# =============================================================================
# ClawdBot Integration
# =============================================================================

# Home directory for the clawdbot process (defaults to ~/.clawdbot).
CLAWDBOT_HOME=

# Persistent state directory for clawdbot (defaults inside CLAWDBOT_HOME).
CLAWDBOT_STATE_DIR=

# Path to the clawdbot binary (defaults to "clawdbot" on PATH).
CLAWDBOT_BIN=

# Temporary log directory used by clawdbot during session spawning.
CLAWDBOT_TMP_LOG_DIR=


# =============================================================================
# Hermes Integration
# =============================================================================

# Path to the hermes-agent binary. Tries "hermes-agent" then "hermes" on PATH.
HERMES_BIN=


# =============================================================================
# GNAP (Git-based Note And Planning) Sync
# =============================================================================

# Enable the GNAP sync engine (default: false).
GNAP_ENABLED=

# Local filesystem path for the GNAP repo/workspace.
GNAP_REPO_PATH=

# Remote Git URL for GNAP data replication (optional).
GNAP_REMOTE_URL=

# Auto-sync on every write (default: true). Set to 'false' to sync manually.
GNAP_AUTO_SYNC=


# =============================================================================
# GitHub Integration
# =============================================================================

# Personal access token or GitHub App token for the GitHub sync panel.
# Scopes: repo (read) is sufficient for most features.
GITHUB_TOKEN=

# Default repo in "owner/repo" format shown when no repo is selected in the UI.
GITHUB_DEFAULT_REPO=

# How often (ms) the GitHub sync poller checks for new events.
# Default: 60000 (1 minute).
GITHUB_SYNC_INTERVAL_MS=


# =============================================================================
# Jarvis Voice Assistant
# =============================================================================

# Enable Jarvis server-side features. Set to 'true' to activate.
JARVIS_ENABLED=
# Client-side Jarvis toggle (controls whether the orb renders at all).
NEXT_PUBLIC_JARVIS_ENABLED=

# Host and port for the Jarvis WebSocket server (defaults: localhost:8340).
JARVIS_HOST=localhost
JARVIS_PORT=8340
NEXT_PUBLIC_JARVIS_HOST=
NEXT_PUBLIC_JARVIS_PORT=

# Full WebSocket URL for Jarvis (overrides HOST + PORT when set).
NEXT_PUBLIC_JARVIS_WS_URL=

# Auth token required by the Jarvis server. Stored server-side; also exposed
# client-side via NEXT_PUBLIC_JARVIS_AUTH_TOKEN for UI connectivity checks.
JARVIS_AUTH_TOKEN=
NEXT_PUBLIC_JARVIS_AUTH_TOKEN=


# =============================================================================
# AI / LLM Integrations
# =============================================================================

# Ollama local LLM base URL (e.g. http://localhost:11434).
OLLAMA_HOST=

# Hyperbrowser cloud browser API key (used by the Hyperbrowser plugin).
HYPERBROWSER_API_KEY=

# Gamma API key for AI-powered marketing presentation generation.
GAMMA_API_KEY=


# =============================================================================
# Coordinator & Agent Identity
# =============================================================================

# Agent ID that acts as the coordinator for system-wide chat and comms.
MC_COORDINATOR_AGENT=coordinator
NEXT_PUBLIC_COORDINATOR_AGENT=coordinator

# Agent ID used for cron-triggered tasks. Falls back to MC_COORDINATOR_AGENT.
MC_CRON_AGENT_ID=

# Default gateway name seeded into an empty database.
MC_DEFAULT_GATEWAY_NAME=primary

# Default organisation name shown in the status panel.
MC_DEFAULT_ORG_NAME=

# Gateway name assigned to the owner account during tenant bootstrap.
MC_DEFAULT_OWNER_GATEWAY=

# Provider subscription list (comma-separated provider IDs) used by the
# provider-subscriptions engine to filter active integrations.
MC_SUBSCRIBED_PROVIDERS=

# Maximum webhook delivery retries before a webhook is marked as failed.
MC_WEBHOOK_MAX_RETRIES=5

# Path to the Claude home directory used by server-side Claude sessions.
MC_CLAUDE_HOME=


# =============================================================================
# Skills Directories
# =============================================================================

# Override the resolved paths for each skill source.
# Defaults are derived from $HOME/.agents/skills, $HOME/.codex/skills, etc.
# MC_SKILLS_USER_AGENTS_DIR=
# MC_SKILLS_USER_CODEX_DIR=
# MC_SKILLS_PROJECT_AGENTS_DIR=
# MC_SKILLS_PROJECT_CODEX_DIR=
# MC_SKILLS_OPENCLAW_DIR=
# MC_SKILLS_WORKSPACE_DIR=


# =============================================================================
# Data Paths
# =============================================================================

# Root data directory (defaults to .data/ in project root).
# MISSION_CONTROL_DATA_DIR=.data

# Override individual file paths inside the data directory.
# MISSION_CONTROL_DB_PATH=.data/mission-control.db
# MISSION_CONTROL_TOKENS_PATH=.data/mission-control-tokens.json

# Workspace directory for agent workspace files.
# MISSION_CONTROL_WORKSPACE_DIR=

# Build-time data overrides (used by CI and test matrix pipelines).
# MISSION_CONTROL_BUILD_DATA_DIR=
# MISSION_CONTROL_BUILD_DB_PATH=
# MISSION_CONTROL_BUILD_TOKENS_PATH=


# =============================================================================
# Super Admin / Provisioning
# =============================================================================

# Path to this repo root; required by super-admin provisioning helpers.
# MISSION_CONTROL_REPO_ROOT=/path/to/mission-control

# Template openclaw.json used to seed new tenant state.
# MC_SUPER_TEMPLATE_OPENCLAW_JSON=/path/to/openclaw.json

# Base path for provisioned Linux user home directories (default: /home).
# MC_TENANT_HOME_ROOT=/home

# Workspace directory name under each tenant user home (default: workspace).
# MC_TENANT_WORKSPACE_DIRNAME=workspace

# Unix socket path for the provisioner daemon.
# MC_PROVISIONER_SOCKET=/run/mc-provisioner.sock

# Shared secret for authenticating calls to the provisioner daemon.
# MC_PROVISIONER_TOKEN=

# Provisioning mode: daemon | sudo | command (default: daemon).
# MC_SUPER_PROVISION_MODE=daemon

# Safety flag: set to 'true' to allow non-dry-run super-admin provisioning.
# Never enable in shared / multi-tenant environments without careful review.
# MC_SUPER_PROVISION_EXEC=false


# =============================================================================
# Data Retention (days; 0 = keep forever)
# =============================================================================

# MC_RETAIN_ACTIVITIES_DAYS=90
# MC_RETAIN_AUDIT_DAYS=365
# MC_RETAIN_GATEWAY_SESSIONS_DAYS=30
# MC_RETAIN_LOGS_DAYS=30
# MC_RETAIN_NOTIFICATIONS_DAYS=60
# MC_RETAIN_PIPELINE_RUNS_DAYS=90
# MC_RETAIN_TOKEN_USAGE_DAYS=90


# =============================================================================
# Flight Deck Integration (local tooling launcher)
# =============================================================================

# Filesystem path to the Flight Deck binary or project root.
FLIGHT_DECK_PATH=

# Base HTTP URL for server-to-server Flight Deck API calls.
FLIGHT_DECK_URL=

# URL used to launch Flight Deck in the browser (may differ from API URL).
FLIGHT_DECK_LAUNCH_URL=


# =============================================================================
# 1Password Integration (optional)
# =============================================================================

# Vault name queried by the Integrations panel via the 1Password CLI (op).
OP_VAULT_NAME=default


# =============================================================================
# Testing / CI
# =============================================================================

# Activate test mode: skips certain writes and uses an in-memory DB overlay.
# Never set to '1' in production.
# MISSION_CONTROL_TEST_MODE=

# Allow cron jobs to be manually triggered via POST /api/cron?action=trigger.
# Disabled by default; enable in dev/test environments only.
# MISSION_CONTROL_ALLOW_COMMAND_TRIGGER=
